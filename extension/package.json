{
  "name": "aevi",
  "displayName": "aevi",
  "description": "AI coding assistant powered by local and cloud LLMs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aevi.openChat",
        "title": "aevi: Open Chat"
      },
      {
        "command": "aevi.indexWorkspace",
        "title": "aevi: Index Workspace"
      },
      {
        "command": "aevi.selectModel",
        "title": "aevi: Select Model"
      },
      {
        "command": "aevi.toggleInlineCompletion",
        "title": "aevi: Toggle Inline Completions"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aevi",
          "title": "aevi",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "aevi": [
        {
          "type": "webview",
          "id": "aevi.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "aevi",
      "properties": {
        "aevi.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "URL of the aevi backend server"
        },
        "aevi.enableInlineCompletion": {
          "type": "boolean",
          "default": false,
          "description": "(Beta) Enable inline code completions. Works best with codellama or qwen2.5-coder models."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}